# ─────────────────────────────────────────────────────────────
# RAG HR Assistant — 환경변수 템플릿
# cp .env.example .env  후 값을 채우세요. (.env 는 git에 커밋되지 않습니다)
# ─────────────────────────────────────────────────────────────

# ── ★ 제품 브랜딩 (도입 회사만 바꾸면 되는 값) ──
COMPANY_NAME=ACME                 # 프롬프트·인사말에 쓰이는 회사명
APP_NAME=HR Assistant             # 챗봇 표시 이름 (프론트·타이틀)

# ── 배포 ──
APP_VERSION=v1.0.0
HTTP_PORT=8080                    # 외부 접속 포트 (nginx)
TZ=Asia/Seoul

# ── 인증 / 보안 (필수) ──
JWT_SECRET_KEY=                   # 예: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                   # 관리자 초기 비밀번호 (강하게)
USER_PASSWORD=changeme            # 일반 계정 초기 비밀번호

# ── 모델 (로컬 vLLM) ──
CHAT_MODEL=LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct-AWQ
AVAILABLE_MODELS=LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct-AWQ

# ── 문서 파싱 ──
LLAMA_CLOUD_API_KEY=              # (선택) LlamaParse 정밀 파싱. 없으면 PyMuPDF 로컬 파싱만 사용
SCAN_OCR_FALLBACK=1               # 스캔본(이미지 PDF) OCR 폴백. 외부전송 불가 시 0
SCAN_CHAR_THRESHOLD=50

# ── RAG 튜닝 (선택) ──
RERANK_THRESHOLD=0.05
PROJECT_RETRIEVER_CACHE_MAX=30
# DOC_NAME_PREFIX_REGEX=DY[\s\d\-]+          # 문서 파일명에 코드 접두어가 있을 때만
# ZERO_HIT_REG_KEYWORDS=연차,휴가,급여,복지  # 지식공백 규정/일반 자동분류 키워드

# ── 웹 검색 (선택) ──
# SEARXNG_URL=http://searxng:8080/search    # SearXNG 인스턴스가 있을 때만. 없으면 웹 폴백 자동 비활성
ALLOWED_ORIGINS=*

# ── 이메일 알림 (선택) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                        # 발신 이메일
SMTP_PASSWORD=                    # 앱 비밀번호
ALERT_EMAIL=                      # 수신 이메일
