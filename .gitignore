# 환경변수 (절대 커밋 금지)
.env

# 자동 백업 파일
backups/

# 런타임 데이터 — 사용자 문서·인덱스·캐시·DB (커밋 금지)
data/documents/*
!data/documents/.gitkeep
data/databases/
data/parsed_cache/

# Docker 빌드 캐시
.dockerignore

# Node
node_modules/
frontend/.next/

# Python
__pycache__/
*.pyc
*.pyo

# 로그 파일
logs/

# 에이전트/에디터 내부 파일
frontend/AGENTS.md
frontend/CLAUDE.md
.claude/

# SSL 인증서 (비밀키 포함 — 절대 커밋 금지)
certs/

# 작업 부산물
*.bak
*_bak
*.bak_*
